# MongoDB Configuration (MongoDB Atlas recommended)
MONGODB_URI="mongodb+srv://<username>:<password>@<cluster>.mongodb.net/outreach_platform?retryWrites=true&w=majority&tls=true"

# LLM Providers (The system automatically tries Gemini -> Cerebras -> Groq for fallback resilience)
GEMINI_API_KEY="your-gemini-api-key"
CEREBRAS_API_KEY="your-cerebras-api-key"
GROQ_API_KEY="your-groq-api-key"

# Intelligence & Discovery APIs
TAVILY_API_KEY="your-tavily-api-key"
FIRECRAWL_API_KEY="your-firecrawl-api-key"

# Email Configuration (Gmail SMTP for outreach delivery)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
TESTING_EMAIL_ADDRESS="your-email@gmail.com"

# System Config
PROJECT_NAME="Autonomous Backlink Outreach"
API_V1_STR="/api/v1"
BACKEND_CORS_ORIGINS="http://localhost:3000"
MAX_RETRIES=3
USE_MOCK_SEARCH=false
USE_MOCK_CRAWLER=false
